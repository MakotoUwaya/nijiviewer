{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "renovate"
  ],
  "dependencyDashboard": true,
  "schedule": [
    "before 4am on Saturday"
  ],
  "timezone": "Asia/Tokyo",
  "packageRules": [
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true
    },
    {
      "description": "Group Storybook packages",
      "groupName": "storybook",
      "matchPackageNames": [
        "storybook",
        "@storybook/nextjs-vite",
        "@storybook/react",
        "@storybook/addon-links",
        "@storybook/addon-onboarding",
        "@storybook/addon-vitest",
        "msw-storybook-addon",
        "@chromatic-com/storybook"
      ],
      "patch": {
        "enabled": false
      }
    },
    {
      "description": "Group Playwright packages",
      "groupName": "playwright",
      "matchPackageNames": [
        "mcr.microsoft.com/playwright",
        "@playwright/test",
        "playwright"
      ]
    },
    {
      "description": "Group Vitest packages (vitest core + @vitest/* must move together due to peer constraints)",
      "groupName": "vitest",
      "matchPackageNames": [
        "vitest",
        "@vitest/browser",
        "@vitest/browser-playwright",
        "@vitest/coverage-v8"
      ]
    }
  ],
  "rangeStrategy": "pin"
}
